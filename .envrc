# Akanga Mirin — direnv configuration
# Run `direnv allow` after cloning to activate automatically.
# See docs/foundations/direnv-basics.md for a full walkthrough.

# Create and activate uv-managed virtual environment
[ -d .venv ] || uv venv
source .venv/bin/activate

# Project environment variables
export AKANGA_SRC=./src
export AKANGA_DOCS="$(pwd)/docs"
